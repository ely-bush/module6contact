<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:module6_contact"
             x:Class="module6_contact.MainPage"
             Title="Contacts"
             BackgroundColor="#F2F2F7">

    <CollectionView x:Name="ContactsCollectionView"
                    ItemsSource="{Binding GroupedContacts}"
                    IsGrouped="True"
                    SelectionMode="Single"
                    SelectionChanged="OnContactSelected"
                    Margin="0,8,0,0">

        <!-- Letter header (A, B, C...) -->
        <CollectionView.GroupHeaderTemplate>
            <DataTemplate>
                <Label Text="{Binding GroupKey}"
                       FontSize="13"
                       FontAttributes="Bold"
                       TextColor="#8E8E93"
                       Padding="20,12,0,4"
                       BackgroundColor="#F2F2F7"/>
            </DataTemplate>
        </CollectionView.GroupHeaderTemplate>

        <!-- Each contact row -->
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="local:Contact">
                <Grid Padding="16,8" ColumnSpacing="14" BackgroundColor="White">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="52"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Circular photo -->
                    <Image Grid.Column="0"
                           Source="{Binding PhotoFileName}"
                           WidthRequest="52"
                           HeightRequest="52"
                           Aspect="AspectFill">
                        <Image.Clip>
                            <EllipseGeometry Center="26,26" RadiusX="26" RadiusY="26"/>
                        </Image.Clip>
                    </Image>

                    <!-- Name -->
                    <Label Grid.Column="1"
                           Text="{Binding Name}"
                           FontSize="16"
                           TextColor="#1C1C1E"
                           VerticalOptions="Center"/>
                </Grid>
            </DataTemplate>
        </CollectionView.ItemTemplate>

    </CollectionView>
</ContentPage>